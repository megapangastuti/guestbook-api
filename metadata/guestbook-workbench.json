{
  "projectName": "guestbook",
  "databaseType": "postgres",
  "endpoints": {
    "users": {
      "tableName": "users",
      "displayName": "Users",
      "action": {
        "datatables": true,
        "create": true,
        "update": true,
        "delete": true,
        "first": true,
        "lookup": true,
        "read": true,
        "export": false,
        "import": false,
        "adjust": false,
        "aggregate": false,
        "createComposite": false,
        "updateComposite": false,
        "readComposite": false,
        "workflow": false
      },
      "primaryKey": "id",
      "fieldName": [
        "id",
        "name",
        "email",
        "password",
        "role",
        "created_at",
        "updated_at"
      ],
      "fieldValidation": [
        {
          "name": "id",
          "type": "uuid",
          "constraints": {
            "primaryKey": true,
            "required": true,
            "autoGenerate": true
          }
        },
        {
          "name": "name",
          "type": "string",
          "constraints": {
            "required": true,
            "maxLength": 100,
            "trim": true
          }
        },
        {
          "name": "email",
          "type": "string",
          "constraints": {
            "required": true,
            "format": "email",
            "maxLength": 150,
            "unique": true,
            "trim": true,
            "lowercase": true
          }
        },
        {
          "name": "password",
          "type": "string",
          "constraints": {
            "required": true,
            "minLength": 8
          }
        },
        {
          "name": "role",
          "type": "enum",
          "constraints": {
            "required": true,
            "enum": [
              "ADMIN",
              "RECEPTIONIST"
            ],
            "default": "RECEPTIONIST"
          }
        },
        {
          "name": "created_at",
          "type": "timestamp",
          "constraints": {
            "required": true,
            "default": "CURRENT_TIMESTAMP",
            "readonly": true
          }
        },
        {
          "name": "updated_at",
          "type": "timestamp",
          "constraints": {
            "required": true,
            "default": "CURRENT_TIMESTAMP",
            "readonly": true,
            "autoUpdate": true
          }
        }
      ],
      "samples": {
        "create": {
          "name": "Demo Name",
          "email": "demo@example.com",
          "password": "Demo password",
          "role": "ADMIN",
          "created_at": "CURRENT_TIMESTAMP",
          "updated_at": "CURRENT_TIMESTAMP"
        },
        "update": {
          "name": "Updated Demo Name",
          "email": "updated@example.com",
          "password": "Demo password",
          "role": "ADMIN",
          "created_at": "CURRENT_TIMESTAMP",
          "updated_at": "CURRENT_TIMESTAMP"
        },
        "delete": {
          "where": [
            {
              "key": "id",
              "value": "sample-id"
            }
          ]
        },
        "get": {
          "where": [
            {
              "key": "id",
              "value": "sample-id"
            }
          ],
          "select": [
            "id",
            "name",
            "email",
            "password",
            "role",
            "created_at",
            "updated_at"
          ]
        },
        "read": {
          "page": 1,
          "per_page": 10,
          "search_value": "",
          "search_by": "name"
        },
        "datatables": {
          "draw": 1,
          "start": 0,
          "length": 10,
          "search": {
            "value": ""
          }
        },
        "lookup": {
          "select": [
            "id",
            "name"
          ]
        }
      }
    }
  },
  "processors": {}
}